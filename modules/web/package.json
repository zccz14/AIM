{
  "name": "@aim-ai/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec vite",
    "build:dist": "pnpm exec vite build",
    "build": "pnpm run build:dist && pnpm run test:type && pnpm run test:lint && pnpm run test:web",
    "preview": "pnpm exec vite preview",
    "typecheck": "pnpm exec tsc --project tsconfig.json --noEmit",
    "test:type": "[ -n \"$SKIP_TEST\" ] || pnpm run typecheck",
    "test:lint": "[ -n \"$SKIP_TEST\" ] || pnpm --dir ../.. exec biome check modules/web/package.json modules/web/src modules/web/test",
    "test:web": "[ -n \"$SKIP_TEST\" ] || pnpm --dir ../.. exec playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@aim-ai/contract": "workspace:*",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "tailwindcss": "^4.2.4",
    "vite": "^7.1.12"
  }
}
